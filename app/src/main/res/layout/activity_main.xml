<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainIbtissam"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F8F9FA"
    android:gravity="center_horizontal">

    <TextView
        android:id="@+id/txtTitreIbtissam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lab Asynchrone : Ibtissam"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/txtStatusIbtissam"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Statut : Prêt"
        android:textSize="16sp"
        android:textColor="#546E7A"
        android:layout_marginBottom="32dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center">

            <ProgressBar
                android:id="@+id/progressBarIbtissam"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:max="100"
                android:progress="0"
                android:visibility="invisible"
                android:progressTint="#3F51B5"/>

            <ImageView
                android:id="@+id/imgIbtissam"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginTop="24dp"
                android:src="@mipmap/ic_launcher_round"
                android:contentDescription="Aperçu Ibtissam"
                android:scaleType="centerInside"
                android:elevation="4dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLoadIbtissam"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Charger Image (Thread)"
        android:layout_marginBottom="16dp"
        app:cornerRadius="16dp"
        android:textAllCaps="false"
        android:textSize="17sp"
        android:backgroundTint="#00897B"
        app:icon="@android:drawable/ic_menu_gallery"
        app:elevation="6dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCalcIbtissam"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Calcul Lourd (AsyncTask)"
        android:layout_marginBottom="16dp"
        app:cornerRadius="16dp"
        android:textAllCaps="false"
        android:textSize="17sp"
        android:backgroundTint="#3F51B5"
        app:icon="@android:drawable/ic_menu_compass"
        app:elevation="6dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToastIbtissam"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Afficher Toast"
        app:cornerRadius="16dp"
        android:textAllCaps="false"
        android:textSize="17sp"
        android:backgroundTint="#D81B60"
        app:icon="@android:drawable/ic_dialog_info"
        app:elevation="6dp"/>

</LinearLayout>